Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"S0", "[", "kx_", "]"}], "=", 
   RowBox[{
    RowBox[{"Sqrt", "[", 
     RowBox[{"a", "/", "d"}], "]"}], "*", 
    RowBox[{
     RowBox[{"Sin", "[", 
      RowBox[{"kx", "*", 
       RowBox[{"a", "/", "2"}]}], "]"}], "/", 
     RowBox[{"(", 
      RowBox[{"kx", "*", 
       RowBox[{"a", "/", "2"}]}], ")"}]}]}]}], ";"}]], "Input",
