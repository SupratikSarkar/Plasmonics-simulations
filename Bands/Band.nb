Cell[BoxData[
 RowBox[{"ContourPlot", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{"kx", "^", "2"}], "-", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{"w", "/", "c0"}], ")"}], "^", "2"}]}], "==", 
      RowBox[{
       RowBox[{
        RowBox[{"(", 
         RowBox[{"w", "/", "c0"}], ")"}], "^", "2"}], "*", 
       RowBox[{
        RowBox[{"Tan", "[", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{"w", "/", "c0"}], ")"}], "*", "h"}], "]"}], "^", "2"}], "*", 
       RowBox[{
        RowBox[{"S0", "[", "kx", "]"}], "^", "4"}]}]}], ",", 
     RowBox[{"w", "==", 
      RowBox[{"c0", "*", "kx"}]}]}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{"kx", ",", "0", ",", 
     RowBox[{"(", 
      RowBox[{"Pi", "/", "d"}], ")"}]}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{"w", ",", "0", ",", 
     RowBox[{"(", 
      RowBox[{"Pi", "*", 
       RowBox[{"c0", "/", 
        RowBox[{"(", 
         RowBox[{"2", "*", "h"}], ")"}]}]}], ")"}]}], "}"}], ",", 
   "\[IndentingNewLine]", 
   RowBox[{"LabelStyle", "\[Rule]", 
    RowBox[{"{", "Black", "}"}]}], ",", 
   RowBox[{"AspectRatio", "->", "1"}], ",", 
   RowBox[{"Frame", "\[Rule]", "True"}], ",", 
