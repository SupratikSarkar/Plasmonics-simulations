Cell[TextData[{
 "Here we use ",
 Cell[BoxData[
  FormBox[
   RowBox[{"t", "=", 
    RowBox[{
     RowBox[{"(", 
      RowBox[{
       SubscriptBox["t", "0"], "/", "3"}], ")"}], 
     RowBox[{"(", 
      RowBox[{"\[Lambda]", "-", "800"}], ")"}]}]}], TraditionalForm]],
  ExpressionUUID->"518c36ac-262f-4553-82c6-41447b046b83"],
 " in ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["\[Beta]", "0"], "=", 
    RowBox[{
     SubscriptBox["k", "y"], "-", 
     RowBox[{"2", 
      RowBox[{"tcos", "(", 
       RowBox[{
        SubscriptBox["k", "x"], "\[CapitalLambda]"}], ")"}]}]}]}], 
   TraditionalForm]],ExpressionUUID->"51036988-9168-4d8e-a496-8ddc9a5ef7f9"],
 ":\nWe can flip the dispersion by controlling \[Lambda]:"
}], "Text",
 CellChangeTimes->{{3.9218450368803186`*^9, 3.921845097299549*^9}, {
  3.9218597114157844`*^9, 3.921859821210316*^9}, {3.921859851732658*^9, 
