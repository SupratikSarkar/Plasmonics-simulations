Cell[TextData[{
 "Here we use ",
 Cell[BoxData[
  FormBox[
   RowBox[{"t", "=", 
    RowBox[{
     RowBox[{"(", 
      RowBox[{
       SubscriptBox["t", "0"], "/", "3"}], ")"}], 
     RowBox[{"(", 
      RowBox[{"\[Omega]", "-", 
       RowBox[{"2", 
        RowBox[{"\[Pi]", "/", "800"}]}]}], ")"}]}]}], TraditionalForm]],
  ExpressionUUID->"9328f967-f571-49d5-b4de-706be888818b"],
 " in ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["\[Beta]", "0"], "=", 
    RowBox[{
     SubscriptBox["k", "y"], "-", 
     RowBox[{"2", 
      RowBox[{"tcos", "(", 
       RowBox[{
        SubscriptBox["k", "x"], "\[CapitalLambda]"}], ")"}]}]}]}], 
   TraditionalForm]],ExpressionUUID->"83d94f37-8455-4356-9d5b-d6f0c0edbcaa"],
 ":\nWe can flip the dispersion by controlling \[Omega]:"
}], "Text",
